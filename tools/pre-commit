#!/usr/bin/env bash
#
# mod-reforge pre-commit hook (org workflow: gitleaks + linters + guards).
#
# mod-reforge is its own git repo, developed standalone and added to an AzerothCore checkout as a
# submodule (modules/mod-reforge). The hook mirrors CI so problems surface before the remote:
#   1. gitleaks    -- secret scan of the staged change.
#   2. core-purity -- src/core/ must not depend on AzerothCore.
#   3. codestyle-cpp.py -- C++ style (uses the parent AzerothCore checkout's linter if present).
#   4. standalone core tests -- fast build + run of the pure-core GoogleTests.
#
# INSTALL (from the module repo root):
#   ln -sf ../../tools/pre-commit .git/hooks/pre-commit
#
# Skip once (emergencies only):  git commit --no-verify
# Requires: bash, cmake, a C++20 compiler. gitleaks / clang-format / python3 are optional.

set -euo pipefail

# Resolve through the .git/hooks/ symlink chain so paths are relative to the REAL tools/ dir,
# not the symlink's location under .git/hooks/.
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "${SOURCE}" ]]; do
    DIR="$(cd -- "$(dirname -- "${SOURCE}")" >/dev/null 2>&1 && pwd)"
    SOURCE="$(readlink -- "${SOURCE}")"
    [[ "${SOURCE}" != /* ]] && SOURCE="${DIR}/${SOURCE}"
done
HOOK_PATH="$(cd -- "$(dirname -- "${SOURCE}")" >/dev/null 2>&1 && pwd)"
MODULE_ROOT="$(cd -- "${HOOK_PATH}/.." >/dev/null 2>&1 && pwd)"
# Parent AzerothCore checkout (modules/<this>/../..); absent on a bare module clone.
CODESTYLE_DIR="${MODULE_ROOT}/../../apps/codestyle"

fail=0
note()  { printf '\033[1;34m[pre-commit]\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m[pre-commit][warn]\033[0m %s\n' "$*"; }
bad()   { printf '\033[1;31m[pre-commit][FAIL]\033[0m %s\n' "$*"; fail=1; }

# --- 1. gitleaks (secret scan) ----------------------------------------------------------------
if command -v gitleaks >/dev/null 2>&1; then
    note "gitleaks: scanning staged changes..."
    if ! gitleaks protect --staged --redact --no-banner; then
        bad "gitleaks found potential secrets in the staged change."
    fi
else
    warn "gitleaks not installed -- skipping secret scan (install: https://github.com/gitleaks/gitleaks)."
fi

# --- 2. core-purity ---------------------------------------------------------------------------
note "core-purity: checking src/core/ for AzerothCore dependencies..."
if ! bash "${MODULE_ROOT}/tools/core-purity.sh"; then
    bad "core-purity guard failed."
fi

# --- 3. codestyle-cpp -------------------------------------------------------------------------
if [[ -f "${CODESTYLE_DIR}/codestyle-cpp.py" ]] && command -v python3 >/dev/null 2>&1; then
    note "codestyle-cpp: linting src..."
    if ! ( cd "${MODULE_ROOT}" && python3 "${CODESTYLE_DIR}/codestyle-cpp.py" ); then
        bad "codestyle-cpp.py reported violations."
    fi
else
    warn "codestyle-cpp.py not found (parent AzerothCore checkout absent) -- skipping C++ lint."
fi

# --- 4. standalone fast core tests ------------------------------------------------------------
note "standalone tests: building + running the pure-core GoogleTests..."
BUILD_DIR="$(mktemp -d)"
trap 'rm -rf "${BUILD_DIR}"' EXIT
if cmake -S "${MODULE_ROOT}/tests/standalone" -B "${BUILD_DIR}" >/dev/null 2>&1 \
    && cmake --build "${BUILD_DIR}" -j"$(nproc 2>/dev/null || echo 2)" >/dev/null 2>&1; then
    if ! "${BUILD_DIR}/reforge_core_tests"; then
        bad "standalone core tests failed."
    fi
else
    bad "standalone core test build failed (see: cmake -S tests/standalone -B <dir>)."
fi

if [[ "${fail}" -ne 0 ]]; then
    printf '\033[1;31m[pre-commit] commit blocked -- fix the issues above or use --no-verify to bypass.\033[0m\n'
    exit 1
fi

note "all gates passed."
exit 0
